<Application
    x:Class="NoteForge.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NoteForge">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="TopBar" Color="#363636"/>
            <SolidColorBrush x:Key="SideBar" Color="#262626"/>
            <SolidColorBrush x:Key="AppSurface" Color="#3F3F3F"/>
            <SolidColorBrush x:Key="AppSurfaceDark" Color="#111111"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#DADADA"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#B3B3B3"/>
            <SolidColorBrush x:Key="Separator" Color="#333333"/>
            <SolidColorBrush x:Key="Primary" Color="#007ACC"/>
            <SolidColorBrush x:Key="Gray500" Color="#808080"/>
            <SolidColorBrush x:Key="Gray600" Color="#606060"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
