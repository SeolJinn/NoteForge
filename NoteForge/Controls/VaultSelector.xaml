<UserControl
    x:Class="NoteForge.Controls.VaultSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NoteForge.Models"
    HorizontalAlignment="Stretch">

    <Button Background="#1E1E1E"
            BorderThickness="1"
            BorderBrush="{StaticResource Separator}"
            CornerRadius="6"
            Padding="12,10"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Click="OnVaultSelectorClicked">
        <Button.Resources>
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#333333"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#404040"/>
        </Button.Resources>
        <Grid ColumnDefinitions="Auto, *, Auto">
            <FontIcon Grid.Column="0"
                      Glyph="&#xE8B7;"
                      FontSize="14"
                      Foreground="{StaticResource Primary}"
                      Margin="0,0,10,0"/>
            <TextBlock Grid.Column="1"
                       x:Name="CurrentVaultName"
                       Text="No vault selected"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <FontIcon Grid.Column="2"
                      x:Name="VaultDropdownIcon"
                      Glyph="&#xE70D;"
                      FontSize="10"
                      Foreground="{StaticResource TextSecondary}"
                      Margin="8,0,0,0"/>
        </Grid>
        <Button.Flyout>
            <Flyout x:Name="VaultFlyout"
                    Placement="Top"
                    Opening="OnVaultFlyoutOpening"
                    Closing="OnVaultFlyoutClosing">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter">
                        <Setter Property="Background" Value="#262626"/>
                        <Setter Property="BorderBrush" Value="#404040"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Padding" Value="8"/>
                    </Style>
                </Flyout.FlyoutPresenterStyle>
                <StackPanel Width="220" Spacing="0">
                    <TextBlock Text="VAULTS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#888888"
                               Margin="4,0,0,8"/>

                    <ListView x:Name="VaultsList"
                              SelectionMode="Single"
                              SelectionChanged="OnVaultSelected"
                              MaxHeight="200"
                              Background="Transparent">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:VaultInfo">
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        CornerRadius="6"
                                        Tag="{x:Bind}"
                                        Click="OnVaultItemClicked">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#343434"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3A3A"/>
                                    </Button.Resources>
                                    <Grid Padding="10,8" ColumnDefinitions="Auto, *">
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE8B7;"
                                                  FontSize="12"
                                                  Foreground="#888888"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="13"
                                                       Foreground="#DADADA"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Path}"
                                                       FontSize="10"
                                                       Foreground="#888888"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Rectangle Height="1"
                               Fill="#404040"
                               Margin="0,10,0,8"/>

                    <Button Content="Manage Vaults"
                            Click="OnManageVaultsClicked"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="#DADADA"
                            BorderThickness="0"
                            CornerRadius="6"
                            Padding="10,8"
                            HorizontalContentAlignment="Left">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#343434"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3A3A"/>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
