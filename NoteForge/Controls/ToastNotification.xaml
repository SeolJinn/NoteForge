<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NoteForge.Controls.ToastNotification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    HorizontalAlignment="Right"
    VerticalAlignment="Bottom"
    Margin="0,0,16,16">

    <UserControl.Resources>
        <Storyboard x:Name="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="ToastContainer"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="20" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="FadeOutStoryboard" Completed="OnFadeOutCompleted">
            <DoubleAnimation Storyboard.TargetName="ToastContainer"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="20" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <!-- Toast panel -->
    <Border x:Name="ToastContainer"
            Opacity="0"
            Background="#3C1518"
            BorderBrush="#6B2529"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,10"
            MinWidth="200"
            MaxWidth="400">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="20"/>
        </Border.RenderTransform>
        <Grid ColumnDefinitions="Auto, *, Auto">
            <!-- Error icon -->
            <FontIcon Grid.Column="0"
                      Glyph="&#xE7BA;"
                      FontSize="14"
                      Foreground="#E8616A"
                      VerticalAlignment="Center"
                      Margin="0,0,10,0"/>

            <!-- Message -->
            <TextBlock Grid.Column="1"
                       x:Name="MessageText"
                       Foreground="#DADADA"
                       FontSize="13"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>

            <!-- Close button -->
            <Button Grid.Column="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Height="20"
                    Width="20"
                    CornerRadius="10"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Click="OnCloseClicked">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                </Button.Resources>
                <FontIcon Glyph="&#xE711;"
                          FontSize="10"
                          Foreground="#B3B3B3"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
