<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NoteForge.Controls.SectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NoteForge.Models"
    xmlns:converters="using:NoteForge.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:SidebarBackgroundColorConverter x:Key="SidebarBackgroundColorConverter"/>
    </UserControl.Resources>

    <Grid Margin="0,4,0,0"
          Visibility="{x:Bind Section.IsVisible, Mode=OneWay}"
          AllowDrop="True"
          DragOver="OnNoteDragOver"
          Drop="OnNoteDrop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section Header -->
        <Grid Grid.Row="0"
              Background="Transparent"
              Padding="10,8"
              Tapped="OnHeaderTapped"
              PointerEntered="OnHeaderPointerEntered"
              PointerExited="OnHeaderPointerExited">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="{x:Bind Section.IsExpanded, Converter={StaticResource BoolToChevronConverter}, Mode=OneWay}"
                          FontSize="10"
                          Foreground="{StaticResource TextSecondary}"
                          VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind Section.Name, Mode=OneWay}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind Section.Notes.Count, Mode=OneWay}"
                           FontSize="11"
                           Foreground="{StaticResource Gray600}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Grid.ContextFlyout>
                <MenuFlyout Placement="RightEdgeAlignedTop"
                            Opening="OnContextMenuOpening">
                    <MenuFlyout.MenuFlyoutPresenterStyle>
                        <Style TargetType="MenuFlyoutPresenter">
                            <Setter Property="Background" Value="{StaticResource SideBar}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Separator}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Padding" Value="4"/>
                        </Style>
                    </MenuFlyout.MenuFlyoutPresenterStyle>
                    <MenuFlyoutItem Text="Rename section"
                                    Click="OnRenameSectionClicked"
                                    Foreground="#DADADA"
                                    Visibility="{x:Bind Section.IsBuiltIn, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8AC;" FontFamily="Segoe MDL2 Assets"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Delete section"
                                    Click="OnDeleteSectionClicked"
                                    Foreground="#DADADA"
                                    Visibility="{x:Bind Section.IsBuiltIn, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Grid.ContextFlyout>
        </Grid>

        <!-- Notes List -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{x:Bind Section.Notes, Mode=OneWay}"
                      Visibility="{x:Bind Section.IsExpanded, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:Note">
                    <Border CornerRadius="8"
                            Margin="10,2,10,2"
                            Padding="15,10"
                            Background="{x:Bind IsSelected, Converter={StaticResource SidebarBackgroundColorConverter}, Mode=OneWay}"
                            Tapped="OnNoteTapped"
                            CanDrag="True"
                            DragStarting="OnNoteDragStarting">
                        <Border.ContextFlyout>
                            <MenuFlyout Placement="RightEdgeAlignedTop">
                                <MenuFlyout.MenuFlyoutPresenterStyle>
                                    <Style TargetType="MenuFlyoutPresenter">
                                        <Setter Property="Background" Value="{StaticResource SideBar}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Separator}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="Padding" Value="4"/>
                                    </Style>
                                </MenuFlyout.MenuFlyoutPresenterStyle>
                                <MenuFlyoutItem Text="Toggle favorite"
                                                Tag="{x:Bind}"
                                                Click="OnToggleFavoriteClicked"
                                                Foreground="#DADADA">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE734;" FontFamily="Segoe MDL2 Assets"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Border.ContextFlyout>
                        <TextBlock Text="{x:Bind Filename, Mode=OneWay}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
