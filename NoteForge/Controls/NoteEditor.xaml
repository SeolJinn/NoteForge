<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NoteForge.Controls.NoteEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <TextBox x:Name="NoteTitleEntry"
                     FontSize="30"
                     FontWeight="Bold"
                     PlaceholderText="Untitled"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextPrimary}"
                     Background="Transparent"
                     BorderThickness="0"
                     TextChanged="OnTitleTextChanged"
                     LostFocus="OnTitleUnfocused" />
            <Button Grid.Column="1"
                    x:Name="GenerateSummaryButton"
                    Background="Transparent"
                    BorderBrush="{StaticResource Primary}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    Click="OnGenerateSummaryClicked"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1A007acc"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#33007acc"/>
                </Button.Resources>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="✨"
                              FontSize="14"
                              Foreground="{StaticResource Primary}"/>
                    <TextBlock Text="Generate AI Summary"
                               FontSize="13"
                               Foreground="{StaticResource Primary}"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                x:Name="AiSummaryContainer"
                Visibility="Collapsed"
                Background="{StaticResource SideBar}"
                BorderBrush="{StaticResource Primary}"
                BorderThickness="2"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,20">
            <Grid RowDefinitions="Auto, *, Auto">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="✨"
                              FontSize="16"
                              Foreground="{StaticResource Primary}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="AI Summary"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1"
                              MaxHeight="200"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,12">
                    <TextBlock x:Name="AiSummaryText"
                               Text="Generating summary..."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13"
                               LineHeight="20"/>
                </ScrollViewer>
                <Button Grid.Row="2"
                        x:Name="CloseSummaryButton"
                        Content="Dismiss"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource TextSecondary}"
                        FontSize="12"
                        Padding="8,4"
                        CornerRadius="6"
                        Click="OnCloseSummaryClicked"
                        HorizontalAlignment="Right">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#007ACC"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#007ACC"/>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <WebView2 x:Name="EditorWebView"
                  Grid.Row="2"
                  DefaultBackgroundColor="Transparent" />
    </Grid>
</UserControl>
