<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NoteForge.Controls.GraphViewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackground}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TabViewButtonBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="TabViewButtonBackgroundPointerOver" Color="#363636"/>
        <SolidColorBrush x:Key="TabViewButtonBackgroundPressed" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="TabViewButtonForeground" Color="#DADADA"/>
        <SolidColorBrush x:Key="TabViewButtonForegroundPointerOver" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TabViewButtonForegroundPressed" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#363636"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="ButtonForeground" Color="#DADADA"/>
        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundUnchecked" Color="#DADADA"/>
        <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundUncheckedPointerOver" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundUncheckedPressed" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="SliderTrackFill" Color="#363636"/>
        <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#404040"/>
        <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#404040"/>
        <SolidColorBrush x:Key="SliderThumbBackground" Color="#007ACC"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#0088dd"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#006bb3"/>
    </UserControl.Resources>

    <Grid>
        <Canvas x:Name="GraphCanvas"
                Background="Transparent"
                PointerPressed="OnCanvasPointerPressed"
                PointerMoved="OnCanvasPointerMoved"
                PointerReleased="OnCanvasPointerReleased"
                SizeChanged="OnCanvasSizeChanged">

            <Canvas x:Name="EdgesCanvas" />

            <Canvas x:Name="NodesCanvas" />
        </Canvas>

        <Border Background="{StaticResource SideBar}"
                BorderBrush="{StaticResource Separator}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20"
                MinWidth="250">
            <StackPanel Spacing="12">
                <TextBlock Text="Graph Controls"
                          FontSize="16"
                          FontWeight="SemiBold"
                          Foreground="{StaticResource TextPrimary}"/>

                <CheckBox x:Name="ShowExplicitLinksCheckbox"
                         Content="Explicit Links"
                         IsChecked="True"
                         Foreground="{StaticResource TextPrimary}"
                         Checked="OnSettingsChanged"
                         Unchecked="OnSettingsChanged"/>

                <CheckBox x:Name="ShowSemanticLinksCheckbox"
                         Content="Semantic Links"
                         IsChecked="True"
                         Foreground="{StaticResource TextPrimary}"
                         Checked="OnSettingsChanged"
                         Unchecked="OnSettingsChanged"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="Semantic Threshold"
                              FontSize="12"
                              Foreground="{StaticResource TextSecondary}"/>
                    <Slider x:Name="SemanticThresholdSlider"
                           Minimum="0"
                           Maximum="1"
                           Value="0.3"
                           StepFrequency="0.05"
                           ValueChanged="OnSettingsChanged"/>
                    <TextBlock x:Name="SemanticThresholdText"
                              FontSize="11"
                              Foreground="{StaticResource TextSecondary}"
                              HorizontalAlignment="Right"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="TF-IDF Threshold"
                              FontSize="12"
                              Foreground="{StaticResource TextSecondary}"/>
                    <Slider x:Name="TfidfThresholdSlider"
                           Minimum="0"
                           Maximum="1"
                           Value="0.2"
                           StepFrequency="0.05"
                           ValueChanged="OnSettingsChanged"/>
                    <TextBlock x:Name="TfidfThresholdText"
                              FontSize="11"
                              Foreground="{StaticResource TextSecondary}"
                              HorizontalAlignment="Right"/>
                </StackPanel>

                <Button x:Name="ResetLayoutButton"
                       Content="Reset Layout"
                       HorizontalAlignment="Stretch"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Click="OnResetLayoutClicked"/>
            </StackPanel>
        </Border>

        <Border x:Name="LoadingOverlay"
                Visibility="Collapsed"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="12">
                <TextBlock Text="⏳"
                          FontSize="48"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Building graph..."
                          FontSize="16"
                          Foreground="{StaticResource TextPrimary}"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
