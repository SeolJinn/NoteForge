<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NoteForge.Controls.TabBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NoteForge.Models"
    xmlns:converters="using:NoteForge.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:TabBackgroundColorConverter x:Key="TabBackgroundColorConverter"/>
    </UserControl.Resources>

    <Grid VerticalAlignment="Bottom">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0"
                      x:Name="TabScrollViewer"
                      HorizontalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Disabled"
                      PointerWheelChanged="OnTabScrollViewerPointerWheelChanged"
                      Height="36">
            <ListView x:Name="TabsCollection"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      VerticalAlignment="Bottom"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="OnTabClicked"
                      CanReorderItems="True"
                      CanDragItems="True"
                      AllowDrop="True"
                      Height="36">
            <ListView.Resources>
                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent"/>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent"/>
            </ListView.Resources>

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="2,0,2,0"/>
                    <Setter Property="MinHeight" Value="32"/>
                    <Setter Property="VerticalAlignment" Value="Bottom"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Tab">
                    <Border Background="{x:Bind IsActive, Converter={StaticResource TabBackgroundColorConverter}, Mode=OneWay}"
                            CornerRadius="8,8,0,0"
                            Padding="12,0,4,0"
                            Height="32"
                            VerticalAlignment="Bottom"
                            BorderBrush="{StaticResource Separator}"
                            BorderThickness="1,1,1,0">

                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="6" VerticalAlignment="Center" Width="180">
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind DisplayName, Mode=OneWay}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="1"
                                       Text="•"
                                       Foreground="{StaticResource Primary}"
                                       FontSize="18"
                                       Visibility="{x:Bind IsDirty, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       Margin="0,-2,0,0"/>

                            <Button Grid.Column="2"
                                        Content="✕"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource TextSecondary}"
                                        FontSize="10"
                                        Padding="0"
                                        Height="20"
                                        Width="20"
                                        CornerRadius="10"
                                        Click="OnCloseTabClicked"
                                        Tag="{x:Bind}"
                                        VerticalAlignment="Center">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </ScrollViewer>

        <Button Grid.Column="1"
                Background="Transparent"
                Width="28"
                Height="28"
                CornerRadius="6"
                Padding="0"
                Margin="4,0,4,4"
                VerticalAlignment="Bottom"
                Click="OnNewTabClicked">
            <FontIcon Glyph="&#xE710;"
                      FontSize="12"
                      Foreground="#B3B3B3"
                      FontFamily="Segoe MDL2 Assets"/>
            <Button.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#434343"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#434343"/>
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
            </Button.Resources>
        </Button>

        <!-- Scroll Indicators -->
        <Border Grid.Column="0"
                x:Name="LeftScrollIndicator"
                Width="20"
                Height="36"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#80000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border Grid.Column="0"
                x:Name="RightScrollIndicator"
                Width="20"
                Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#80000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
    </Grid>
</UserControl>
