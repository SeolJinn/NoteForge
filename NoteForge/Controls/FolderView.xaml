<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NoteForge.Controls.FolderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NoteForge.Models"
    xmlns:controls="using:NoteForge.Controls"
    xmlns:converters="using:NoteForge.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:SidebarBackgroundColorConverter x:Key="SidebarBackgroundColorConverter"/>
        <converters:BoolToChevronConverter x:Key="BoolToChevronConverter"/>
    </UserControl.Resources>

    <Grid Margin="0,4,0,0" AllowDrop="True" DragOver="OnFolderDragOver" Drop="OnFolderDrop" DragLeave="OnFolderDragLeave">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Vertical Hierarchy Line -->
        <Rectangle Grid.Column="0"
                   Grid.Row="0"
                   Grid.RowSpan="2"
                   Width="2"
                   Margin="10,24,0,0"
                   Fill="{StaticResource Separator}"
                   x:Name="HierarchyLine"
                   Visibility="{x:Bind Folder.IsExpanded, Mode=OneWay}"/>

        <!-- Folder Header -->
        <Grid Grid.Column="0"
              Grid.ColumnSpan="2"
              Grid.Row="0"
              x:Name="HeaderGrid"
              Background="Transparent"
              Padding="10,8"
              Tapped="OnHeaderTapped"
              PointerEntered="OnHeaderPointerEntered"
              PointerExited="OnHeaderPointerExited">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="{x:Bind Folder.IsExpanded, Converter={StaticResource BoolToChevronConverter}, Mode=OneWay}"
                          FontSize="10"
                          Foreground="{StaticResource TextSecondary}"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="FolderNameTextBlock"
                           Text="{x:Bind Folder.Name, Mode=OneWay}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Grid.ContextFlyout>
                <MenuFlyout Placement="RightEdgeAlignedTop">
                    <MenuFlyout.MenuFlyoutPresenterStyle>
                        <Style TargetType="MenuFlyoutPresenter">
                            <Setter Property="Background" Value="{StaticResource SideBar}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Separator}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Padding" Value="4"/>
                        </Style>
                    </MenuFlyout.MenuFlyoutPresenterStyle>
                    <MenuFlyoutItem Text="New folder"
                                    Click="OnCreateSubfolderClicked"
                                    Foreground="#DADADA">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8F4;" FontSize="16"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Rename folder"
                                    Click="OnRenameFolderClicked"
                                    Foreground="#DADADA">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8AC;" FontFamily="Segoe MDL2 Assets"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Delete folder"
                                    Click="OnDeleteFolderClicked"
                                    Foreground="#DADADA">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Grid.ContextFlyout>
        </Grid>

        <!-- Content Area (Subfolders and Notes) -->
        <Grid Grid.Column="1"
              Grid.Row="1"
              Visibility="{x:Bind Folder.IsExpanded, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Subfolders (Recursive) -->
            <StackPanel Grid.Row="0"
                        x:Name="SubfoldersControl"
                        Margin="4,0,0,0"/>

            <!-- Notes List -->
            <ItemsControl Grid.Row="1"
                          x:Name="NotesItemsControl"
                          ItemsSource="{x:Bind Folder.Notes, Mode=OneWay}"
                          Margin="4,0,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Note">
                        <Border CornerRadius="8"
                                Margin="10,2,10,2"
                                Padding="15,10"
                                Background="{x:Bind IsSelected, Converter={StaticResource SidebarBackgroundColorConverter}, Mode=OneWay}"
                                Tapped="OnNoteTapped"
                                CanDrag="True"
                                DragStarting="OnNoteDragStarting">
                            <Border.ContextFlyout>
                                <MenuFlyout Placement="RightEdgeAlignedTop">
                                    <MenuFlyout.MenuFlyoutPresenterStyle>
                                        <Style TargetType="MenuFlyoutPresenter">
                                            <Setter Property="Background" Value="{StaticResource SideBar}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Separator}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="CornerRadius" Value="8"/>
                                            <Setter Property="Padding" Value="4"/>
                                        </Style>
                                    </MenuFlyout.MenuFlyoutPresenterStyle>
                                    <MenuFlyoutItem Text="Toggle favorite"
                                                    Tag="{x:Bind}"
                                                    Click="OnToggleFavoriteClicked"
                                                    Foreground="#DADADA">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE734;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Rename note"
                                                    Tag="{x:Bind}"
                                                    Click="OnRenameNoteClicked"
                                                    Foreground="#DADADA">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8AC;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Delete note"
                                                    Tag="{x:Bind}"
                                                    Click="OnDeleteNoteClicked"
                                                    Foreground="#fb464c">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Border.ContextFlyout>
                            <TextBlock Text="{x:Bind Filename, Mode=OneWay}"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Drop Zone Highlight Overlay -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="0"
                Grid.RowSpan="2"
                x:Name="DropZoneOverlay"
                Background="#3366BFFF"
                BorderBrush="{StaticResource Primary}"
                BorderThickness="2"
                CornerRadius="4"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
