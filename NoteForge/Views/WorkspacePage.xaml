<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NoteForge.Models"
             xmlns:converters="clr-namespace:NoteForge.Converters"
             x:Class="NoteForge.Views.WorkspacePage"
             BackgroundColor="{StaticResource AppBackground}"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <converters:TabHoverColorConverter x:Key="TabHoverConverter" />
    </ContentPage.Resources>

    <!-- Main Layout -->
    <Grid RowDefinitions="32, *" Padding="0">

        <!-- Unified Header / Title Bar Container -->
        <Grid Grid.Row="0"
              x:Name="AppTitleBar"
              BackgroundColor="{StaticResource TopBar}"
              ColumnDefinitions="Auto, *, Auto"
              Padding="0">

            <!-- Sidebar Toggle & Spacer -->
            <Grid Grid.Column="0">
                <!-- Spacer matches sidebar width -->
                <BoxView WidthRequest="250"
                         HeightRequest="1"
                         Color="Transparent"
                         IsVisible="{Binding IsVisible, Source={x:Reference Sidebar}}"/>

                <Button Text="☰"
                        FontSize="20"
                        TextColor="{StaticResource TextPrimary}"
                        BackgroundColor="Transparent"
                        WidthRequest="40"
                        HeightRequest="40"
                        Margin="10,0,0,0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Clicked="OnToggleSidebarClicked"/>
            </Grid>

            <!-- Tab Bar -->
            <ScrollView Grid.Column="1"
                        Orientation="Horizontal"
                        BackgroundColor="Transparent"
                        HeightRequest="36"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never"
                        VerticalOptions="End"
                        HorizontalOptions="Start">
                <CollectionView x:Name="TabsCollection"
                                ItemsLayout="HorizontalList"
                                SelectionMode="Single"
                                SelectionChanged="OnTabSelected"
                                HeightRequest="36">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Tab">
                            <Border Stroke="Transparent"
                                    StrokeShape="RoundRectangle 8,8,0,0"
                                    BackgroundColor="Transparent"
                                    Padding="12,0,4,0"
                                    Margin="4,4,0,0"
                                    HeightRequest="32"
                                    VerticalOptions="End">

                                <!-- Active Tab Styling -->
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="{Binding IsActive, Converter={StaticResource TabHoverConverter}}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="6" VerticalOptions="Center" WidthRequest="180">
                                    <Label Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation"/>

                                    <Label Grid.Column="1"
                                           Text="•"
                                           TextColor="{StaticResource Primary}"
                                           FontSize="18"
                                           IsVisible="{Binding IsDirty}"
                                           VerticalOptions="Center"
                                           Margin="0,-2,0,0"/>

                                    <Button Grid.Column="2"
                                            Text="✕"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource TextSecondary}"
                                            FontSize="8"
                                            Padding="0"
                                            HeightRequest="16"
                                            WidthRequest="16"
                                            MinimumHeightRequest="16"
                                            MinimumWidthRequest="16"
                                            CornerRadius="8"
                                            Clicked="OnCloseTabClicked"
                                            CommandParameter="{Binding .}"
                                            VerticalOptions="Center"
                                            Opacity="0.7">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor" Value="#33FFFFFF" />
                                                        <Setter Property="Opacity" Value="1" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *">

            <!-- Sidebar -->
            <Grid Grid.Column="0"
                  x:Name="Sidebar"
                  WidthRequest="250"
                  BackgroundColor="{StaticResource SideBar}"
                  RowDefinitions="Auto, *, Auto">

                <!-- Sidebar Header -->
                <VerticalStackLayout Grid.Row="0" Padding="10" Spacing="5">
                    <Label x:Name="PathLabel" Text="Path: ..." FontSize="10" TextColor="{StaticResource Gray600}" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <!-- Notes List -->
                <CollectionView Grid.Row="1" x:Name="NotesCollection" SelectionMode="Single" SelectionChanged="OnNoteSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Note">
                            <Grid Padding="15,10">
                                <Label Text="{Binding Filename}"
                                       FontSize="14"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Sidebar Footer -->
                <VerticalStackLayout Grid.Row="2" Padding="10" Spacing="10">
                    <Button Text="Change Folder" Clicked="OnChangeFolderClicked" FontSize="12" />
                    <Button Text="Refresh Notes" Clicked="OnRefreshClicked" FontSize="12" />
                </VerticalStackLayout>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Column="1" Padding="0">
                <!-- Placeholder State -->
                <Grid x:Name="EmptyStateView" IsVisible="True">
                    <Label Text="Select a note to view"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{StaticResource Gray500}" />
                </Grid>

                <!-- Editor View -->
                <Grid x:Name="EditorView" IsVisible="False" RowDefinitions="Auto, *" Padding="20">

                    <!-- Title / Actions -->
                    <Grid Grid.Row="0" ColumnDefinitions="*" Margin="0,0,0,20">
                        <Entry x:Name="NoteTitleEntry"
                               FontSize="30"
                               FontAttributes="Bold"
                               Placeholder="Untitled"
                               VerticalOptions="Center"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"
                               TextChanged="OnNoteTitleTextChanged"
                               Completed="OnTitleCompleted"
                               Unfocused="OnTitleUnfocused" />
                    </Grid>

                    <!-- Editor -->
                    <Editor Grid.Row="1"
                            x:Name="NoteContentEditor"
                            Placeholder="Start typing..."
                            VerticalOptions="Fill"
                            VerticalTextAlignment="Start"
                            AutoSize="TextChanges"
                            TextChanged="OnNoteContentChanged" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</ContentPage>