<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NoteForge.Views.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NoteForge.Models"
    xmlns:converters="using:NoteForge.Converters"
    mc:Ignorable="d"
    Background="{StaticResource AppBackground}">

    <Page.Resources>
        <converters:TabBackgroundColorConverter x:Key="TabBackgroundColorConverter"/>
        <converters:SidebarBackgroundColorConverter x:Key="SidebarBackgroundColorConverter"/>
        
        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlForeground" Color="#DADADA" />
        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#DADADA" />
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#DADADA" />
        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#007ACC" Opacity="0.5" />
        <SolidColorBrush x:Key="TextControlSelectionForegroundBrush" Color="#FFFFFF" />
        
        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#B3B3B3" />
        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#B3B3B3" />
        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#B3B3B3" />
    </Page.Resources>

    <Grid RowDefinitions="Auto, *" Padding="0">

        <!-- Unified Header / Title Bar Container -->
        <Grid Grid.Row="0"
              x:Name="AppTitleBar"
              Background="{StaticResource TopBar}"
              Padding="0"
              Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TitleBarSidebarColumn" Width="250" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Toggle -->
            <Grid Grid.Column="0">
                <Button Content="☰"
                        FontSize="16"
                        Foreground="{StaticResource TextPrimary}"
                        Background="Transparent"
                        Width="40"
                        Height="40"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="OnToggleSidebarClicked"/>
            </Grid>

            <!-- Tab Bar -->
            <ListView Grid.Column="1"
                      x:Name="TabsCollection"
                      ScrollViewer.HorizontalScrollMode="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      ScrollViewer.VerticalScrollMode="Disabled"
                      VerticalAlignment="Bottom"
                      HorizontalAlignment="Stretch"
                      SelectionMode="Single"
                      SelectionChanged="OnTabSelected"
                      CanReorderItems="True"
                      CanDragItems="True"
                      AllowDrop="True"
                      Height="36">
                    <ListView.Resources>
                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent"/>
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent"/>
                    </ListView.Resources>

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="2,0,2,0"/>
                            <Setter Property="MinHeight" Value="32"/>
                            <Setter Property="VerticalAlignment" Value="Bottom"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Tab">
                            <Border Background="{x:Bind IsActive, Converter={StaticResource TabBackgroundColorConverter}, Mode=OneWay}"
                                    CornerRadius="8,8,0,0"
                                    Padding="12,0,4,0"
                                    Height="32"
                                    VerticalAlignment="Bottom"
                                    BorderBrush="{StaticResource Separator}"
                                    BorderThickness="1,1,1,0">
                                
                                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="6" VerticalAlignment="Center" Width="180">
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DisplayName, Mode=OneWay}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="1"
                                               Text="•"
                                               Foreground="{StaticResource Primary}"
                                               FontSize="18"
                                               Visibility="{x:Bind IsDirty, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               Margin="0,-2,0,0"/>

                                <Button Grid.Column="2"
                                                Content="✕"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{StaticResource TextSecondary}"
                                                FontSize="10"
                                                Padding="0"
                                                Height="20"
                                                Width="20"
                                                CornerRadius="10"
                                                Click="OnCloseTabClicked"
                                                Tag="{x:Bind}"
                                                VerticalAlignment="Center">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *">

            <!-- Sidebar -->
            <Grid Grid.Column="0"
                  x:Name="Sidebar"
                  Width="250"
                  Background="{StaticResource SideBar}"
                  RowDefinitions="Auto, *, Auto">

                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Padding="10" Spacing="5">
                    <TextBlock x:Name="PathLabel" Text="Path: ..." FontSize="10" Foreground="{StaticResource Gray600}" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Notes List -->
                <ListView Grid.Row="1" x:Name="NotesCollection" SelectionMode="Single" SelectionChanged="OnNoteSelected">
                    <ListView.Resources>
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Note">
                            <Border CornerRadius="8" 
                                    Margin="10,2,10,2" 
                                    Padding="15,10"
                                    Background="{x:Bind IsSelected, Converter={StaticResource SidebarBackgroundColorConverter}, Mode=OneWay}">
                                <TextBlock Text="{x:Bind Filename, Mode=OneWay}"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Sidebar Footer -->
                <StackPanel Grid.Row="2" Padding="10" Spacing="10">
                    <Button Content="Change Folder" Click="OnChangeFolderClicked" FontSize="12" HorizontalAlignment="Stretch"/>
                    <Button Content="Refresh Notes" Click="OnRefreshClicked" FontSize="12" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Column="1" Padding="0">
                <!-- Placeholder State -->
                <Grid x:Name="EmptyStateView" Visibility="Visible">
                    <TextBlock Text="Select a note to view"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Gray500}" />
                </Grid>

                <!-- Editor View -->
                <Grid x:Name="EditorView" Visibility="Collapsed" RowDefinitions="Auto, *" Padding="20">

                    <!-- Title / Actions -->
                    <Grid Grid.Row="0" ColumnDefinitions="*" Margin="0,0,0,20">
                        <TextBox x:Name="NoteTitleEntry"
                                 FontSize="30"
                                 FontWeight="Bold"
                                 PlaceholderText="Untitled"
                                 VerticalAlignment="Center"
                                 Foreground="{StaticResource TextPrimary}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 TextChanged="OnNoteTitleTextChanged"
                                 LostFocus="OnTitleUnfocused" />
                    </Grid>

                    <!-- Editor -->
                    <TextBox Grid.Row="1"
                             x:Name="NoteContentEditor"
                             PlaceholderText="Start typing..."
                             VerticalAlignment="Stretch"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="OnNoteContentChanged" 
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimary}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>

