<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NoteForge.Views.CreateVaultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackground}">

    <Page.Resources>
        <SolidColorBrush x:Key="TextControlBackground" Color="#2a2a2a" />
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2a2a2a" />
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2a2a2a" />
        <SolidColorBrush x:Key="TextControlForeground" Color="#DADADA" />
        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#DADADA" />
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#DADADA" />
        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
        
        <SolidColorBrush x:Key="TextControlDeleteButtonForeground" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlDeleteButtonForegroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="TextControlDeleteButtonForegroundPressed" Color="Transparent" />

        <SolidColorBrush x:Key="ButtonBackground" Color="#363636"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#3f3f3f"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3f3f3f"/>
        <SolidColorBrush x:Key="ButtonForeground" Color="#DADADA"/>
        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#DADADA"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>

        <Style x:Key="SolidButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#363636"/>
            <Setter Property="Foreground" Value="#DADADA"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Page.Resources>

    <StackPanel Spacing="20" Padding="30" VerticalAlignment="Center">
        <TextBlock Text="Create local vault" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   HorizontalTextAlignment="Center" 
                   HorizontalAlignment="Center"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <!-- Vault Name Section -->
        <Grid ColumnDefinitions="*, 200" ColumnSpacing="15">
             <StackPanel Grid.Column="0" VerticalAlignment="Center">
                 <TextBlock Text="Vault Name" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}"/>
                 <TextBlock Text="Pick a name for your NoteForge vault." Foreground="{StaticResource TextSecondary}" FontSize="12"/>
             </StackPanel>
             <TextBox Grid.Column="1" 
                      x:Name="VaultNameEntry" 
                      PlaceholderText="Vault name"
                      VerticalAlignment="Center"
                      CornerRadius="8"
                      Loaded="OnVaultNameEntryLoaded"
                      TextChanged="OnVaultNameChanged"/>
        </Grid>

        <Rectangle Height="1" Fill="{StaticResource Separator}" Margin="0,10" />

        <!-- Location Section -->
        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
             <StackPanel Grid.Column="0" VerticalAlignment="Center">
                 <TextBlock Text="Location" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}"/>
                 <TextBlock Text="Pick a place to put your new vault." Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                 <TextBlock x:Name="PathLabel" Text="Not selected" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,5,0,0"/>
             </StackPanel>
             <Button Grid.Column="1" 
                     Content="Browse" 
                     Click="OnBrowseClicked" 
                     Style="{StaticResource SolidButtonStyle}"
                     Width="80"
                     Height="40"
                     VerticalAlignment="Center" />
        </Grid>

        <Button Content="Create" 
                Click="OnCreateClicked" 
                Margin="0,40,0,0"
                IsEnabled="False"
                x:Name="CreateButton"
                Style="{StaticResource SolidButtonStyle}"
                Width="120"
                HorizontalAlignment="Center"/>
                
        <Button Content="←Back" 
                Click="OnCancelClicked" 
                Margin="0,10,0,0"
                Background="Transparent"
                Foreground="{StaticResource TextSecondary}"
                CornerRadius="8"
                Width="120"
                HorizontalAlignment="Center"/>
    </StackPanel>
</Page>

