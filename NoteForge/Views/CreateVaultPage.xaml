<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteForge.Views.CreateVaultPage"
             BackgroundColor="{StaticResource AppBackground}">
    
    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
        <Label Text="Create new vault" 
               FontSize="32" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               TextColor="{StaticResource TextPrimary}"
               Margin="0,0,0,20"/>

        <!-- Vault Name Section -->
        <Grid ColumnDefinitions="*, 200" ColumnSpacing="15">
             <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                 <Label Text="Vault Name" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                 <Label Text="Pick a name for your NoteForge vault." TextColor="{StaticResource TextSecondary}" FontSize="12"/>
             </VerticalStackLayout>
             <Entry Grid.Column="1" 
                    x:Name="VaultNameEntry" 
                    Text="NoteForge" 
                    Placeholder="Vault name"
                    TextColor="{StaticResource TextPrimary}"
                    PlaceholderColor="{StaticResource TextSecondary}"
                    BackgroundColor="{StaticResource AppSurfaceDark}"
                    VerticalOptions="Center"/>
        </Grid>

        <BoxView HeightRequest="1" Color="{StaticResource Separator}" Margin="0,10" />

        <!-- Location Section -->
        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
             <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                 <Label Text="Location" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                 <Label Text="Pick a place to put your new vault." TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                 <Label x:Name="PathLabel" Text="Not selected" TextColor="{StaticResource TextSecondary}" FontSize="10" Margin="0,5,0,0"/>
             </VerticalStackLayout>
             <Button Grid.Column="1" 
                     Text="Browse" 
                     Clicked="OnBrowseClicked" 
                     BackgroundColor="{StaticResource AppSurface}"
                     TextColor="{StaticResource TextPrimary}"
                     WidthRequest="80"
                     HeightRequest="40"
                     VerticalOptions="Center" />
        </Grid>

        <Button Text="Create" 
                Clicked="OnCreateClicked" 
                Margin="0,40,0,0"
                IsEnabled="False"
                x:Name="CreateButton"
                BackgroundColor="{StaticResource AppSurface}"
                TextColor="{StaticResource TextPrimary}"
                WidthRequest="120"
                HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>
