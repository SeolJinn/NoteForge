<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NoteForge.Views.VaultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NoteForge.Views"
    xmlns:models="using:NoteForge.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackground}">

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="10">
                <TextBlock Text="NoteForge" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White" />
                <TextBlock Text="Your personal knowledge base" 
                           FontSize="16" 
                           Foreground="{StaticResource TextSecondary}" />
            </StackPanel>

            <!-- Recent Vaults List -->
            <StackPanel Grid.Row="1" Margin="0,40,0,0" Spacing="15">
                <TextBlock Text="Recent Vaults" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="White" />
                 
                <!-- Empty State -->
                <TextBlock x:Name="EmptyStateLabel"
                           Text="No recent vaults found." 
                           Foreground="{StaticResource TextSecondary}" 
                           FontSize="14"
                           Opacity="0.5" 
                           Visibility="Collapsed"/>

                <ListView x:Name="RecentVaultsCollection" 
                          SelectionMode="Single"
                          SelectionChanged="OnRecentVaultSelected">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,5" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:VaultInfo">
                            <Border Padding="10"
                                    Background="Transparent"
                                    CornerRadius="5">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Bind Name}" 
                                               Foreground="{StaticResource TextPrimary}" 
                                               FontWeight="Bold" 
                                               FontSize="14"/>
                                    <TextBlock Text="{x:Bind Path}" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="12" 
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Actions Footer -->
            <StackPanel Grid.Row="2" Spacing="0">
                <Rectangle Height="1" Fill="{StaticResource Separator}" Margin="0,0,0,20" />
                
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Open folder as vault" 
                                   Foreground="{StaticResource TextPrimary}" 
                                   FontWeight="Bold"/>
                         <TextBlock Text="Open an existing folder of Markdown files" 
                                    Foreground="{StaticResource TextSecondary}" 
                                    FontSize="12"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1"
                            Content="Open"
                            Click="OnOpenVaultClicked"
                            Background="{StaticResource AppSurface}"
                            Foreground="{StaticResource TextPrimary}"
                            Width="100"
                            Height="36"/>
                </Grid>

                <Rectangle Height="1" Fill="{StaticResource Separator}" Margin="0,15" />

                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Create new vault" 
                                   Foreground="{StaticResource TextPrimary}" 
                                   FontWeight="Bold"/>
                         <TextBlock Text="Create a new NoteForge vault under a folder" 
                                    Foreground="{StaticResource TextSecondary}" 
                                    FontSize="12"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1"
                            Content="Create"
                            Click="OnCreateVaultClicked"
                            Background="{StaticResource AppSurface}"
                            Foreground="{StaticResource TextPrimary}"
                            Width="100"
                            Height="36"/>
                </Grid>
            </StackPanel>
            
        </Grid>
    </Grid>
</Page>

