<?xml version="1.0" encoding="utf-8"?>
<local:VaultPageBase
    x:Class="NoteForge.Views.VaultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NoteForge.Views"
    xmlns:models="using:NoteForge.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1e1e1e">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.35*"/>
            <ColumnDefinition Width="0.65*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Section - Recent Vaults (35%) -->
        <Grid Grid.Column="0" Background="#262626">
            <Grid Padding="32,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
                    <TextBlock Text="Recent Vaults" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="#DADADA" />
                </StackPanel>

                <!-- Recent Vaults List -->
                <Grid Grid.Row="1">
                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyStatePanel"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8B7;" 
                                  FontSize="48" 
                                  Foreground="#555555"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,16"/>
                        <TextBlock x:Name="EmptyStateLabel"
                                   Text="No recent vaults" 
                                   Foreground="#888888" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Open or create a vault to get started" 
                                   Foreground="#666666" 
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListView x:Name="RecentVaultsCollection" 
                              SelectionMode="Single"
                              SelectionChanged="OnRecentVaultSelected"
                              Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Grid x:Name="Root">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal"/>
                                                        <VisualState x:Name="PointerOver">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#333333"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Pressed">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#3A3A3A"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Selected">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="PointerOverSelected">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#333333"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="PressedSelected">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#3A3A3A"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                                <Border x:Name="BackgroundBorder" 
                                                        Background="Transparent" 
                                                        CornerRadius="8"/>
                                                <ContentPresenter x:Name="ContentPresenter"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:VaultInfo">
                                <Border Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0" 
                                                Width="40" Height="40" 
                                                CornerRadius="8" 
                                                Background="#3a3a3a"
                                                Margin="0,0,14,0">
                                            <FontIcon Glyph="&#xE8D5;" 
                                                      FontSize="18" 
                                                      Foreground="#B0B0B0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" 
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" 
                                                       Foreground="#DADADA" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="14"/>
                                            <TextBlock Text="{x:Bind Path}" 
                                                       Foreground="#777777" 
                                                       FontSize="12" 
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <!-- Right Section - Actions (65%) -->
        <Grid Grid.Column="1" Background="#1e1e1e">
            <Grid Padding="48,40" VerticalAlignment="Center" MaxWidth="700">
                <StackPanel Spacing="0">
                    <!-- Branding Header -->
                    <StackPanel Spacing="12" Margin="0,0,0,32">
                        <TextBlock Text="NoteForge" 
                                   FontSize="36" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" />
                        <TextBlock Text="Your personal knowledge base" 
                                   FontSize="16" 
                                   Foreground="#888888" />
                    </StackPanel>

                    <!-- Create New Vault Card -->
                    <Border Background="Transparent"
                            Padding="0,16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Create new vault" 
                                           Foreground="#FFFFFF" 
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <TextBlock Text="Create a new NoteForge vault under a folder" 
                                           Foreground="#888888" 
                                           FontSize="13"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Create"
                                    Click="OnCreateVaultClicked"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="100"
                                    Height="40"
                                    VerticalAlignment="Center">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1a8ad4"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF"/>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="#363636" Margin="0,8"/>

                    <!-- Open Folder Card -->
                    <Border Background="Transparent" 
                            Padding="0,16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Open folder as vault" 
                                           Foreground="#FFFFFF" 
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <TextBlock Text="Open an existing folder of Markdown files" 
                                           Foreground="#888888" 
                                           FontSize="13"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Open"
                                    Click="OnOpenVaultClicked"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="100"
                                    Height="40"
                                    VerticalAlignment="Center">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#4a4a4a"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#363636"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#DADADA"/>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</local:VaultPageBase>