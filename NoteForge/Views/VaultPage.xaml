<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NoteForge.Models"
             x:Class="NoteForge.Views.VaultPage"
             BackgroundColor="{StaticResource AppBackground}"
             NavigationPage.HasNavigationBar="False">
    
    <Grid RowDefinitions="Auto, *, Auto" Padding="40">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Label Text="NoteForge" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="White" />
            <Label Text="Your personal knowledge base" 
                   FontSize="16" 
                   TextColor="{StaticResource TextSecondary}" />
        </VerticalStackLayout>

        <!-- Recent Vaults List -->
        <VerticalStackLayout Grid.Row="1" Margin="0,40,0,0" Spacing="15">
             <Label Text="Recent Vaults" 
                    FontSize="14" 
                    FontAttributes="Bold" 
                    TextColor="White" />
             
             <!-- Empty State -->
             <Label x:Name="EmptyStateLabel"
                    Text="No recent vaults found." 
                    TextColor="{StaticResource TextSecondary}" 
                    FontSize="14"
                    Opacity="0.5" 
                    IsVisible="False"/>

             <CollectionView x:Name="RecentVaultsCollection" 
                             SelectionMode="Single"
                             SelectionChanged="OnRecentVaultSelected">
                 <CollectionView.ItemTemplate>
                     <DataTemplate x:DataType="models:VaultInfo">
                         <Border Stroke="Transparent" 
                                 StrokeShape="RoundRectangle 5"
                                 Padding="10"
                                 Margin="0,0,0,5"
                                 BackgroundColor="Transparent">
                             <VisualStateManager.VisualStateGroups>
                                 <VisualStateGroupList>
                                     <VisualStateGroup x:Name="CommonStates">
                                         <VisualState x:Name="Normal" />
                                         <VisualState x:Name="Selected">
                                             <VisualState.Setters>
                                                 <Setter Property="BackgroundColor" Value="{StaticResource AppSurface}" />
                                             </VisualState.Setters>
                                         </VisualState>
                                         <VisualState x:Name="PointerOver">
                                             <VisualState.Setters>
                                                 <Setter Property="BackgroundColor" Value="{StaticResource AppSurfaceDark}" />
                                             </VisualState.Setters>
                                         </VisualState>
                                     </VisualStateGroup>
                                 </VisualStateGroupList>
                             </VisualStateManager.VisualStateGroups>
                             
                             <VerticalStackLayout Spacing="2">
                                 <Label Text="{Binding Name}" 
                                        TextColor="{StaticResource TextPrimary}" 
                                        FontAttributes="Bold" 
                                        FontSize="14"/>
                                 <Label Text="{Binding Path}" 
                                        TextColor="{StaticResource TextSecondary}" 
                                        FontSize="12" 
                                        LineBreakMode="TailTruncation"/>
                             </VerticalStackLayout>
                         </Border>
                     </DataTemplate>
                 </CollectionView.ItemTemplate>
             </CollectionView>
        </VerticalStackLayout>

        <!-- Actions Footer -->
        <VerticalStackLayout Grid.Row="2" Spacing="0">
            <BoxView HeightRequest="1" Color="{StaticResource Separator}" Margin="0,0,0,20" />
            
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="Open folder as vault" 
                           TextColor="{StaticResource TextPrimary}" 
                           FontAttributes="Bold"/>
                     <Label Text="Open an existing folder of Markdown files" 
                            TextColor="{StaticResource TextSecondary}" 
                            FontSize="12"/>
                </VerticalStackLayout>
                
                <Button Grid.Column="1"
                        Text="Open"
                        Clicked="OnOpenVaultClicked"
                        BackgroundColor="{StaticResource AppSurface}"
                        TextColor="{StaticResource TextPrimary}"
                        WidthRequest="100"
                        HeightRequest="36"/>
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource Separator}" Margin="0,15" />

            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="Create new vault" 
                           TextColor="{StaticResource TextPrimary}" 
                           FontAttributes="Bold"/>
                     <Label Text="Create a new NoteForge vault under a folder" 
                            TextColor="{StaticResource TextSecondary}" 
                            FontSize="12"/>
                </VerticalStackLayout>
                
                <Button Grid.Column="1"
                        Text="Create"
                        Clicked="OnCreateVaultClicked"
                        BackgroundColor="{StaticResource AppSurface}"
                        TextColor="{StaticResource TextPrimary}"
                        WidthRequest="100"
                        HeightRequest="36"/>
            </Grid>
        </VerticalStackLayout>
        
    </Grid>
</ContentPage>
